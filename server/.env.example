# Backend Environment Variables - NEVER COMMIT THE ACTUAL .env FILE TO GIT

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?ssl=true

# Server
PORT=5000

# JWT Secrets (Generate strong random strings!)
# Command to generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_generate_strong_random_string
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_generate_strong_random_string

# Admin Account (Use strong password - change immediately after first login)
ADMIN_EMAIL=admin@livaani.com
ADMIN_PASSWORD=change_me_immediately
