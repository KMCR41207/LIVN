# Frontend Environment Variables
# Only add VITE_ prefixed variables that should be exposed to frontend

# Google OAuth (Client ID is public by design - get from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# API URL (use relative path in production - served by same server)
# Leave empty for development (Vite proxy will forward /api to http://localhost:5000)
# VITE_API_URL=http://localhost:5000/api
