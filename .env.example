# ─── FRONTEND ───────────────────────────────────────────────────────────────

# Backend API URL
VITE_API_URL=http://localhost:5000/api

# Google OAuth Client ID
# Get from: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here


# ─── BACKEND (MongoDB + Auth) ───────────────────────────────────────────────

# MongoDB connection string
# Local: mongodb://localhost:27017/livaani
# Cloud: mongodb+srv://username:password@cluster.mongodb.net/livaani
MONGODB_URI=mongodb://localhost:27017/livaani

# JWT signing secret (use a strong 32+ byte string in production)
JWT_SECRET=your_jwt_secret_key_at_least_32_bytes_long_change_this_in_production

# Admin email — automatically assigned admin role on first signup
ADMIN_EMAIL=admin@livaani.com
